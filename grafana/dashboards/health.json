{
  "title": "iPhone Health Data",
  "uid": "iphone-health",
  "schemaVersion": 38,
  "time": {
    "from": "now-1y",
    "to": "now"
  },
  "refresh": "",
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "睡眠",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "睡眠ステージ(日別・積み上げ)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "health-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "SELECT DATE(end_time) || 'T00:00:00Z' as time, ROUND(SUM(CASE WHEN stage='Deep' THEN duration_min ELSE 0 END)/60.0,2) as '深い眠り', ROUND(SUM(CASE WHEN stage='REM' THEN duration_min ELSE 0 END)/60.0,2) as 'REM', ROUND(SUM(CASE WHEN stage='Core' THEN duration_min ELSE 0 END)/60.0,2) as 'コア眠り' FROM sleep WHERE stage IN ('Deep','REM','Core') AND REPLACE(source, char(160), ' ') = 'Meee Apple Watch' GROUP BY DATE(end_time) ORDER BY time",
          "queryType": "table",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "fillOpacity": 80,
            "lineWidth": 0,
            "barAlignment": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "深い眠り"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "REM"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "コア眠り"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "総睡眠時間(日別)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "health-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "SELECT DATE(end_time) || 'T00:00:00Z' as time, ROUND(SUM(duration_min)/60.0,2) as '総睡眠時間' FROM sleep WHERE stage IN ('Deep','REM','Core','Unspecified') AND REPLACE(source, char(160), ' ') = 'Meee Apple Watch' GROUP BY DATE(end_time) ORDER BY time",
          "queryType": "table",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {
            "fillOpacity": 20
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Deep + REM 割合(%)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "health-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "SELECT DATE(end_time) || 'T00:00:00Z' as time, ROUND(100.0 * SUM(CASE WHEN stage IN ('Deep','REM') THEN duration_min ELSE 0 END) / NULLIF(SUM(CASE WHEN stage IN ('Deep','REM','Core','Unspecified') THEN duration_min ELSE 0 END),0), 1) as 'Deep+REM%' FROM sleep WHERE stage IN ('Deep','REM','Core','Unspecified') AND REPLACE(source, char(160), ' ') = 'Meee Apple Watch' GROUP BY DATE(end_time) ORDER BY time",
          "queryType": "table",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 15
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 15
              },
              {
                "color": "green",
                "value": 25
              }
            ]
          }
        }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "運動・アクティビティ",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "title": "日別歩数",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "health-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "SELECT DATE(time) || 'T00:00:00Z' as time, CAST(SUM(value) AS INTEGER) as '歩数' FROM steps GROUP BY DATE(time) ORDER BY time",
          "queryType": "table",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5000
              },
              {
                "color": "green",
                "value": 8000
              }
            ]
          },
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 0,
            "barAlignment": 0
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 5,
      "title": "ワークアウト記録",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "health-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "SELECT DATE(time) as '日付', activity_type as '種別', ROUND(duration_min,1) as '時間(分)', ROUND(distance_km,2) as '距離(km)', ROUND(energy_kcal,0) as 'kcal' FROM workouts ORDER BY time DESC",
          "queryType": "table",
          "timeColumns": ["time"]
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "日時",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "週別運動時間(分)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "health-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%Y-%W', time) as week, MIN(DATE(time)) || 'T00:00:00Z' as time, ROUND(SUM(value), 0) as '運動時間(分)' FROM exercise_time GROUP BY strftime('%Y-%W', time) ORDER BY week",
          "queryType": "table",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "custom": {
            "fillOpacity": 50,
            "lineWidth": 0
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "心肺・回復指標",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "安静時心拍数 (bpm)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "health-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "SELECT time || 'Z' as time, value FROM resting_heart_rate ORDER BY time",
          "queryType": "table",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bpm",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 8,
      "title": "心拍変動 HRV (ms)",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 38,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "health-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "SELECT time || 'Z' as time, value FROM hrv ORDER BY time",
          "queryType": "table",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "fixed",
            "fixedColor": "dark-purple"
          },
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 9,
      "title": "VO2 Max (mL/kg/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 38,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "health-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "SELECT time || 'Z' as time, value FROM vo2max ORDER BY time",
          "queryType": "table",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "dark-green"
          },
          "custom": {
            "fillOpacity": 10
          },
          "decimals": 1
        }
      }
    }
  ]
}
